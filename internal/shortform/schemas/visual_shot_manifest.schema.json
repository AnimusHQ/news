{
  "$id": "https://animus.local/schemas/visual_shot_manifest.schema.json",
  "title": "visual_shot_manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "episode_id", "artifact_id", "created_at", "created_by", "status", "provider", "aspect_ratio", "render_target", "shots"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "episode_id": { "type": "string", "minLength": 1 },
    "artifact_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "created_by": { "type": "string", "minLength": 1 },
    "source_artifacts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "content_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "status": { "enum": ["draft", "in_review", "approved", "rejected", "superseded", "locked"] },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "model": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "aspect_ratio": { "const": "9:16" },
    "render_target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resolution", "aspect", "fps", "video_codec"],
      "properties": {
        "resolution": { "const": "1080x1920" },
        "aspect": { "const": "9:16" },
        "fps": { "const": 30 },
        "video_codec": { "const": "h264" }
      }
    },
    "shots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scene_id", "prompt", "negative_prompt", "reference_image_hash", "output_path", "output_hash", "duration_sec", "status", "operator_approval"],
        "properties": {
          "scene_id": { "type": "string", "minLength": 1 },
          "prompt": { "type": "string", "minLength": 1 },
          "negative_prompt": { "type": "string", "minLength": 1 },
          "reference_image_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
          "output_path": { "type": "string", "minLength": 1 },
          "output_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
          "duration_sec": { "type": "number", "minimum": 0 },
          "camera": { "type": "string" },
          "style": { "type": "string" },
          "status": { "enum": ["draft", "in_review", "approved", "rejected", "superseded", "locked"] },
          "operator_approval": { "type": "boolean" }
        }
      }
    }
  }
}
