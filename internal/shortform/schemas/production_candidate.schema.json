{
  "$id": "https://animus.local/schemas/production_candidate.schema.json",
  "title": "production_candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "episode_id", "artifact_id", "created_at", "created_by", "status", "candidate_id", "immutable", "components"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "episode_id": { "type": "string", "minLength": 1 },
    "artifact_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "created_by": { "type": "string", "minLength": 1 },
    "source_artifacts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "content_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "status": { "enum": ["draft", "in_review", "approved", "rejected", "superseded", "locked"] },
    "candidate_id": { "type": "string", "minLength": 1 },
    "immutable": { "const": true },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_id", "kind", "content_hash"],
        "properties": {
          "artifact_id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "content_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
        }
      }
    }
  }
}
