{
  "$id": "https://animus.local/schemas/uploadpost_publish_manifest.schema.json",
  "title": "uploadpost_publish_manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "episode_id", "artifact_id", "created_at", "created_by", "status", "provider", "mode", "dry_run", "platforms", "visibility", "ai_disclosure_required", "human_release_approval", "production_qa_ref", "release_approval_ref"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "episode_id": { "type": "string", "minLength": 1 },
    "artifact_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "created_by": { "type": "string", "minLength": 1 },
    "source_artifacts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "content_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "status": { "enum": ["draft", "in_review", "approved", "rejected", "superseded", "locked"] },
    "provider": { "const": "upload_post" },
    "mode": { "enum": ["dry_run", "schedule", "publish"] },
    "dry_run": { "type": "boolean" },
    "platforms": { "type": "array", "minItems": 1, "items": { "enum": ["tiktok", "instagram", "youtube"] } },
    "visibility": { "enum": ["private", "scheduled", "public"] },
    "scheduled_at": { "type": "string" },
    "ai_disclosure_required": { "type": "boolean" },
    "ai_disclosure": { "type": "string" },
    "human_release_approval": { "type": "boolean" },
    "production_qa_ref": { "type": "string", "minLength": 1 },
    "release_approval_ref": { "type": "string", "minLength": 1 }
  }
}
