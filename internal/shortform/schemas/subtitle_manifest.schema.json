{
  "$id": "https://animus.local/schemas/subtitle_manifest.schema.json",
  "title": "subtitle_manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "episode_id", "artifact_id", "created_at", "created_by", "status", "provider", "language", "transcript_path", "transcript_hash", "srt_path", "srt_hash", "checks", "operator_approval"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "episode_id": { "type": "string", "minLength": 1 },
    "artifact_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "created_by": { "type": "string", "minLength": 1 },
    "source_artifacts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "content_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "status": { "enum": ["draft", "in_review", "approved", "rejected", "superseded", "locked"] },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "model": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "language": { "type": "string", "minLength": 1 },
    "transcript_path": { "type": "string", "minLength": 1 },
    "transcript_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "srt_path": { "type": "string", "minLength": 1 },
    "srt_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "ass_path": { "type": "string" },
    "ass_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "operator_approval": { "type": "boolean" },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["word_timestamps", "safe_zone", "sync"],
      "properties": {
        "word_timestamps": { "type": "boolean" },
        "safe_zone": { "type": "boolean" },
        "sync": { "type": "boolean" }
      }
    }
  }
}
