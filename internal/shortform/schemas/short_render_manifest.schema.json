{
  "$id": "https://animus.local/schemas/short_render_manifest.schema.json",
  "title": "short_render_manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "episode_id", "artifact_id", "created_at", "created_by", "status", "renderer", "inputs", "outputs"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "episode_id": { "type": "string", "minLength": 1 },
    "artifact_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "created_by": { "type": "string", "minLength": 1 },
    "source_artifacts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "content_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "status": { "enum": ["draft", "in_review", "approved", "rejected", "superseded", "locked"] },
    "renderer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "inputs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["platform", "path", "hash", "resolution", "aspect", "fps", "video_codec", "audio_codec", "audio_track", "duration_sec", "status"],
        "properties": {
          "platform": { "enum": ["tiktok", "instagram", "youtube", "master"] },
          "path": { "type": "string", "minLength": 1 },
          "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
          "resolution": { "const": "1080x1920" },
          "aspect": { "const": "9:16" },
          "fps": { "const": 30 },
          "video_codec": { "const": "h264" },
          "audio_codec": { "const": "aac" },
          "audio_track": { "type": "boolean" },
          "subtitles_burned": { "type": "boolean" },
          "duration_sec": { "type": "number", "minimum": 0 },
          "status": { "enum": ["draft", "in_review", "approved", "rejected", "superseded", "locked"] }
        }
      }
    }
  }
}
