{
  "$id": "https://animus.local/schemas/storyboard_image_manifest.schema.json",
  "title": "storyboard_image_manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "episode_id", "artifact_id", "created_at", "created_by", "status", "source", "images"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "episode_id": { "type": "string", "minLength": 1 },
    "artifact_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "created_by": { "type": "string", "minLength": 1 },
    "source_artifacts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "content_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "status": { "enum": ["draft", "in_review", "approved", "rejected", "superseded", "locked"] },
    "source": { "const": "chatgpt_manual" },
    "operator": { "type": "string" },
    "images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scene_id", "image_path", "image_hash", "version_id", "status"],
        "properties": {
          "scene_id": { "type": "string", "minLength": 1 },
          "image_path": { "type": "string", "minLength": 1 },
          "image_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
          "version_id": { "type": "string", "minLength": 1 },
          "status": { "enum": ["draft", "in_review", "approved", "rejected", "superseded", "locked"] },
          "expected_start_sec": { "type": "number", "minimum": 0 },
          "expected_end_sec": { "type": "number", "minimum": 0 },
          "visual_review_passed": { "type": "boolean" },
          "approved_by": { "type": "string" },
          "approved_at": { "type": "string" }
        }
      }
    }
  }
}
