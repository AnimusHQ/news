# Animus News — environment example (PLACEHOLDERS ONLY).
#
# Copy to a local .env (gitignored) or export in your shell. NEVER commit real
# values. Animus reads these at runtime; CI and `make verify*` must run without
# any real secret, network call, paid API, local model, or deployment.
#
# All providers are opt-in and fail closed when their config is missing.

# ----- Claude API review provider (--claude-review api) -----
ANTHROPIC_API_KEY=
ANIMUS_CLAUDE_MODEL=
ANIMUS_CLAUDE_TIMEOUT=
ANIMUS_CLAUDE_MAX_TOKENS=
ANIMUS_CLAUDE_BASE_URL=

# ----- OpenAI (planned; native image provider deferred to L3) -----
OPENAI_API_KEY=
ANIMUS_OPENAI_MODEL=
ANIMUS_OPENAI_TIMEOUT=
ANIMUS_OPENAI_BASE_URL=

# ----- Visual external-command provider (e.g. Seedance wrapper) -----
ANIMUS_VISUAL_COMMAND=
ANIMUS_VISUAL_INPUT_ROOT=
ANIMUS_VISUAL_OUTPUT_ROOT=
ANIMUS_VISUAL_TIMEOUT=

# ----- Voice external-command provider (e.g. Chatterbox wrapper) -----
ANIMUS_VOICE_COMMAND=
ANIMUS_VOICE_INPUT_ROOT=
ANIMUS_VOICE_OUTPUT_ROOT=
ANIMUS_VOICE_TIMEOUT=

# ----- Subtitle sidecar (faster-whisper) -----
ANIMUS_FASTER_WHISPER_COMMAND=
ANIMUS_FASTER_WHISPER_INPUT_ROOT=
ANIMUS_FASTER_WHISPER_OUTPUT_ROOT=
ANIMUS_FASTER_WHISPER_TIMEOUT=

# ----- FFmpeg render -----
ANIMUS_FFMPEG_BINARY=
ANIMUS_FFPROBE_BINARY=
ANIMUS_FFMPEG_TIMEOUT=

# ----- Wrapper-only env (consumed by example wrappers, NOT by Animus) -----
# CHATTERBOX_BASE_URL=
# CHATTERBOX_VOICE=
# CHATTERBOX_VOICE_CONSENT_REFERENCE=
# SEEDANCE_API_KEY=
# SEEDANCE_BASE_URL=
# SEEDANCE_MODEL=
